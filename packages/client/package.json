{
  "name": "@tiny-type-api/client",
  "version": "1.4.0",
  "description": "library for defining api interface client by TypeScript",
  "keywords": [
    "api",
    "client",
    "typescript"
  ],
  "license": "MIT",
  "author": "koh110",
  "repository": {
    "type": "git",
    "url": "https://github.com/koh110/tiny-type-api.git"
  },
  "type": "module",
  "main": "./dist/esm/src/index.js",
  "types": "./dist/esm/src/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/src/index.d.ts",
        "default": "./dist/esm/src/index.js"
      },
      "require": {
        "types": "./dist/cjs/src/index.d.ts",
        "default": "./dist/cjs/src/index.js"
      },
      "default": "./dist/esm/src/src/index.js"
    }
  },
  "scripts": {
    "format": "vp fmt src --write",
    "lint": "vp lint src",
    "prebuild": "rm -rf dist",
    "build:cjs": "tsc --build tsconfig.cjs.json",
    "build:esm": "tsc --build tsconfig.json",
    "build:test": "tsc --build tsconfig.test.json",
    "build": "npm run build:cjs && npm run build:esm && tsconfig-to-dual-package",
    "pretest": "npm run build:test",
    "test": "node --test src/**/*.test.ts"
  },
  "dependencies": {
    "@tiny-type-api/universal": "^1.4.0",
    "path-to-regexp": "^8.4.0"
  },
  "devDependencies": {
    "typescript": "^6.0.2"
  }
}
